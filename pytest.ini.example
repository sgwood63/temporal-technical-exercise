[pytest]
asyncio_mode = auto
testpaths = tests

# Print logs live to the terminal during the test run (equivalent to -s for logs).
# Remove or set to false to suppress log output and rely on pytest's captured log
# shown only on failure.
log_cli = true
log_cli_level = DEBUG

# Match the format used by logging_config.py so test output is consistent with
# worker and run_workflow output.
log_cli_format = %(asctime)s %(levelname)-8s %(name)s — %(message)s
log_cli_date_format = %Y-%m-%dT%H:%M:%S

# Write all logs to a file as well (useful when running the cloud test suite,
# which takes ~2 minutes and produces a lot of output).
log_file = logs/pytest.log
log_file_level = DEBUG
log_file_format = %(asctime)s %(levelname)-8s %(name)s — %(message)s
log_file_date_format = %Y-%m-%dT%H:%M:%S
