# Copy this file to .env and fill in your Temporal Cloud values.
# Never commit .env to version control.

# Temporal Cloud endpoint: <namespace>.<account-id>.tmprl.cloud:7233
TEMPORAL_ADDRESS=

# Temporal Cloud namespace (e.g. my-namespace.abc123)
TEMPORAL_NAMESPACE=

# Temporal Cloud API key (create one in the Temporal Cloud UI under Settings > API Keys)
TEMPORAL_API_KEY=

# Task queue name — worker and starter must use the same value
TASK_QUEUE=sentiment-analysis

# Path for the local SQLite database file (default: sentiment_results.db in the project root)
DB_PATH=sentiment_results.db
